              <span class="flex items-center gap-1"><Icon name="tabler:bed" class="w-3.5 h-3.5" /> Bedroom</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bed-flat" class="w-3.5 h-3.5" /> Double bed</span>
              <span class="flex items-center gap-1"><Icon name="tabler:tools-kitchen-2" class="w-3.5 h-3.5" /> Kitchen</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bathroom</span>
              <span class="flex items-center gap-1"><Icon name="tabler:droplet" class="w-3.5 h-3.5" /> Shower</span>
              <span class="flex items-center gap-1"><Icon name="tabler:bath" class="w-3.5 h-3.5" /> Bathtub</span>
              <span class="flex items-center gap-1"><Icon name="tabler:toilet-paper" class="w-3.5 h-3.5" /> WC</span>
              <span class="flex items-center gap-1"><Icon name="tabler:device-tv" class="w-3.5 h-3.5" /> TV</span>
              <span class="flex items-center gap-1"><Icon name="tabler:wifi" class="w-3.5 h-3.5" /> Wi-Fi</span>
            </div>
            <AvailabilityCalendar apartment="bergwiese" id="bergwiese" />
            <div class="mt-4 border-t border-gray-200 dark:border-slate-700 pt-4">
              <div class="flex flex-wrap gap-3 mb-3">
                <div>
                  <label for="bfw-pc-checkin-bergwiese" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Check-in</label>
                  <input type="date" id="bfw-pc-checkin-bergwiese" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
                <div>
                  <label for="bfw-pc-checkout-bergwiese" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Check-out</label>
                  <input type="date" id="bfw-pc-checkout-bergwiese" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
              </div>
              <p id="bfw-pc-date-error-bergwiese" class="hidden text-xs text-red-600 mb-2">Minimum 1 night</p>
              <button type="button" id="bfw-pc-cta-bergwiese" disabled class="bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-4 py-2 rounded-full inline-block text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">Send inquiry</button>
            </div>
<script>
(function() {
  var checkinInput = document.getElementById('bfw-pc-checkin-bergwiese');
  var checkoutInput = document.getElementById('bfw-pc-checkout-bergwiese');
  var dateError = document.getElementById('bfw-pc-date-error-bergwiese');
  var ctaButton = document.getElementById('bfw-pc-cta-bergwiese');

  var APARTMENT_SLUG = 'bergwiese';
  var CONTACT_PATH = '/en/contact';
  var ERR_MIN_STAY = 'Minimum 1 night';
  var ERR_PAST_DATE = 'Please choose a future date';

  // BFW-564: build YYYY-MM-DD strings from local-time components so the picker
  // and validation stay correct in any timezone. The previous version that
  // used UTC conversion was off by one day in UTC+N timezones.
  function pad2(n) { return (n < 10 ? '0' : '') + n; }
  function localIso(d) {
    return d.getFullYear() + '-' + pad2(d.getMonth() + 1) + '-' + pad2(d.getDate());
  }
  function todayStr() {
    return localIso(new Date());
  }
  function dayAfter(isoDate) {
    var d = new Date(isoDate + 'T00:00:00');
    d.setDate(d.getDate() + 1);
    return localIso(d);
  }

  function datesValid() {
    var ci = checkinInput ? checkinInput.value : '';
