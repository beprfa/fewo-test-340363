---

<!-- BFW-352: tenant slug + public API base URL for the AvailabilityCalendar widget.
     BFW-532: bookings snapshot embedded so the calendar renders from static HTML
     even when the runtime fetch is blocked (Chrome PNA, mixed content, offline). -->
<script is:inline define:vars={{ tenantSlug: '340363', apiBase: 'http://localhost:9080', bookingsRaw: '[{"apartmentSlug":"bergwiese","startDate":"2026-05-21","endDate":"2026-05-24","status":"BOOKED"},{"apartmentSlug":"alpenpanorama","startDate":"2026-05-08","endDate":"2026-05-13","status":"BOOKED"},{"apartmentSlug":"alpenpanorama","startDate":"2026-05-21","endDate":"2026-05-27","status":"BOOKED"},{"apartmentSlug":"alpenpanorama","startDate":"2026-05-28","endDate":"2026-06-10","status":"BOOKED"},{"apartmentSlug":"bergwiese","startDate":"2026-05-13","endDate":"2026-05-20","status":"BOOKED"},{"apartmentSlug":"bergwiese","startDate":"2026-05-25","endDate":"2026-05-31","status":"BOOKED"},{"apartmentSlug":"alpenpanorama","startDate":"2026-06-25","endDate":"2026-07-03","status":"BOOKED"},{"apartmentSlug":"bergwiese","startDate":"2026-07-09","endDate":"2026-07-12","status":"BOOKED"},{"apartmentSlug":"alpenpanorama","startDate":"2026-06-11","endDate":"2026-06-14","status":"BOOKED"}]' }}>
  window.MFWS_TENANT_SLUG = tenantSlug;
  window.MFWS_PUBLIC_API_BASE_URL = apiBase;
  try {
    window.MFWS_INITIAL_BOOKINGS = bookingsRaw && bookingsRaw.charAt(0) === '[' ? JSON.parse(bookingsRaw) : [];
  } catch (e) {
    window.MFWS_INITIAL_BOOKINGS = [];
  }
</script>

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    actions={[
      {
        variant: 'secondary',
        text: 'Booking Request',
        href: '/en/contact',
        icon: 'tabler:mail',
      },
      { variant: 'primary', text: 'View Apartments', href: '#apartments' },
    ]}
    image={{ src: '~/assets/images/hero-image.jpg', alt: 'Sonnenhof Alpenblick – Holiday Apartments in Aschau im Chiemgau' }}
  >
    <Fragment slot="title">
      <span class="text-primary dark:text-white">Urlaub im Sonnenhof Alpenblick</span>
    </Fragment>

    <Fragment slot="subtitle">
      Willkommen im Sonnenhof Alpenblick – Ihren Ferienwohnungen in Aschau im Chiemgau. Erleben Sie alpines Wohnen am Fuße der Chiemgauer Alpen.
    </Fragment>
  </Hero>

  <!-- Apartments Section *************** -->

  <section id="apartments" class="py-12 md:py-16 bg-blue-50 dark:bg-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center max-w-3xl mx-auto mb-8">
        <p class="text-base text-primary font-bold tracking-wide uppercase mb-2">Holiday Apartments</p>
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight mb-4 font-heading dark:text-gray-200">Your Holiday Apartments in Aschau im Chiemgau</h2>
        <p class="text-lg text-muted dark:text-slate-400">
          Unser Landhaus liegt ruhig und idyllisch am Ortsrand — perfekt zum Abschalten. Wir bieten Ihnen zwei liebevoll eingerichtete Ferienwohnungen, die 2025 renoviert wurden. Auf der sonnigen Gemeinschaftsterrasse lässt sich der Tag bei einem Glas Wein entspannt ausklingen.
        </p>
      </div>

      <div class="flex flex-wrap justify-center gap-x-6 gap-y-3 text-lg text-default dark:text-slate-300 mb-8">
        <span class="flex items-center gap-1.5"><Icon name="tabler:trees" class="w-4 h-4" /> Garden</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sun" class="w-4 h-4" /> Terrace</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:car" class="w-4 h-4" /> Parking</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:paw" class="w-4 h-4" /> Pets allowed</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:flame" class="w-4 h-4" /> BBQ Area</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:mood-kid" class="w-4 h-4" /> Children welcome</span>
        <span class="flex items-center gap-1.5"><Icon name="tabler:sparkles" class="w-4 h-4" /> 2026 renoviert</span>
      </div>

      <div class="grid md:grid-cols-2 gap-6 max-w-3xl mx-auto">
        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
          <ImageCarousel images={alpenpanoramaImages} id="alpenpanorama" />
          <div class="p-5">
            <h3 class="text-xl font-bold mb-2 dark:text-white">Alpenpanorama</h3>
