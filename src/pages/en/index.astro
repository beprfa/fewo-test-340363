                </div>
                <div>
                  <label for="bfw-pc-checkout-alpenpanorama" class="block text-xs font-medium text-muted dark:text-slate-400 mb-1">Check-out</label>
                  <input type="date" id="bfw-pc-checkout-alpenpanorama" class="text-sm px-3 py-2 border border-gray-300 dark:border-slate-600 rounded bg-white dark:bg-slate-700 dark:text-white" />
                </div>
              </div>
              <p id="bfw-pc-date-error-alpenpanorama" class="hidden text-xs text-red-600 mb-2">Minimum 1 night</p>
              <button type="button" id="bfw-pc-cta-alpenpanorama" disabled class="bg-secondary text-white border-secondary hover:bg-primary hover:border-primary px-4 py-2 rounded-full inline-block text-sm font-semibold transition-colors disabled:opacity-50 disabled:cursor-not-allowed">Send inquiry</button>
            </div>
<script>
(function() {
  var checkinInput = document.getElementById('bfw-pc-checkin-alpenpanorama');
  var checkoutInput = document.getElementById('bfw-pc-checkout-alpenpanorama');
  var dateError = document.getElementById('bfw-pc-date-error-alpenpanorama');
  var ctaButton = document.getElementById('bfw-pc-cta-alpenpanorama');

  var APARTMENT_SLUG = 'alpenpanorama';
  var CONTACT_PATH = '/en/contact';
  var ERR_MIN_STAY = 'Minimum 1 night';
  var ERR_PAST_DATE = 'Please choose a future date';

  // BFW-564: build YYYY-MM-DD strings from local-time components so the picker
  // and validation stay correct in any timezone. The previous version that
  // used UTC conversion was off by one day in UTC+N timezones.
  function pad2(n) { return (n < 10 ? '0' : '') + n; }
  function localIso(d) {
    return d.getFullYear() + '-' + pad2(d.getMonth() + 1) + '-' + pad2(d.getDate());
  }
  function todayStr() {
    return localIso(new Date());
  }
  function dayAfter(isoDate) {
    var d = new Date(isoDate + 'T00:00:00');
    d.setDate(d.getDate() + 1);
    return localIso(d);
  }

  function datesValid() {
    var ci = checkinInput ? checkinInput.value : '';
    var co = checkoutInput ? checkoutInput.value : '';
    return !!ci && !!co && co > ci && ci >= todayStr();
  }

  function showDateError(message) {
    if (!dateError) return;
    if (message) {
      dateError.textContent = message;
      dateError.classList.remove('hidden');
    } else {
      dateError.classList.add('hidden');
    }
  }

  function updateButtonState() {
    if (ctaButton) ctaButton.disabled = !datesValid();
  }

  // BFW-564: Pick a specific error message so the user understands why the
  // button is disabled. Past-date check beats the min-stay check because a
  // past date is the more obvious error.
  function refreshErrorAndButton() {
    var today = todayStr();
    var ci = checkinInput ? checkinInput.value : '';
    var co = checkoutInput ? checkoutInput.value : '';
    var ciPast = !!ci && ci < today;
    var coPast = !!co && co < today;
    if (ciPast || coPast) {
      showDateError(ERR_PAST_DATE);
    } else if (!!ci && !!co && co <= ci) {
      showDateError(ERR_MIN_STAY);
    } else {
      showDateError('');
    }
    updateButtonState();
  }

  if (checkinInput) checkinInput.min = todayStr();
  if (checkoutInput) checkoutInput.min = dayAfter(todayStr());

  function onCheckinChange() {
    if (checkinInput && checkinInput.value && checkoutInput) {
      var minOut = dayAfter(checkinInput.value);
      checkoutInput.min = minOut;
      if (checkoutInput.value && checkoutInput.value < minOut) {
        checkoutInput.value = '';
      }
    }
    refreshErrorAndButton();
  }

  function onCheckoutChange() {
    refreshErrorAndButton();
  }

  if (checkinInput) checkinInput.addEventListener('change', onCheckinChange);
  if (checkoutInput) checkoutInput.addEventListener('change', onCheckoutChange);

  if (ctaButton) {
    ctaButton.addEventListener('click', function() {
      if (!datesValid()) return;
      try {
        sessionStorage.setItem('mfws_booking_draft', JSON.stringify({
          apartmentSlug: APARTMENT_SLUG,
          checkIn: checkinInput.value,
          checkOut: checkoutInput.value,
        }));
      } catch (e) { /* sessionStorage may be disabled — fall through */ }
      window.location.href = CONTACT_PATH;
    });
  }

  refreshErrorAndButton();
})();
</script>
          </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-lg overflow-hidden border border-gray-200 dark:border-slate-700">
